# ─────────────────────────────────────────────
# GLOBAL KICKOFF™ — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git
# ─────────────────────────────────────────────

# ── Email Capture (pick one) ──
# Mailchimp
NEXT_PUBLIC_MAILCHIMP_URL=https://your-list-id.us1.list-manage.com/subscribe/post

# ConvertKit
NEXT_PUBLIC_CONVERTKIT_API_KEY=your_convertkit_api_key
NEXT_PUBLIC_CONVERTKIT_FORM_ID=your_form_id

# Resend (for transactional / backend)
RESEND_API_KEY=re_your_resend_api_key

# ── Ticket Platform ──
NEXT_PUBLIC_EVENTBRITE_URL=https://www.eventbrite.com/e/your-event-id

# ── Analytics ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=https://globalkickoff.com
